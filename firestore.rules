rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Direct check for admin role without recursion issues
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users Collection
    match /users/{userId} {
      // Allow read if it's the user's own profile OR if the requester is an admin
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Allow update if it's the user's own profile (but prevent role changes) OR if requester is an admin
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'totalEarnings'])))
      );
      
      // Allow creation during signup - Ensure uid matches and ROLE IS NOT ADMIN
      allow create: if isAuthenticated() && 
                    request.auth.uid == userId && 
                    request.resource.data.uid == request.auth.uid &&
                    (request.resource.data.role == 'associate' || request.resource.data.role == 'clinician');
      
      allow delete: if isAdmin();
    }

    // Cases Collection
    match /cases/{caseId} {
      // Helper to get points (Must match TREATMENT_POINTS in types/index.ts)
      function getPoints(type) {
        let pointsMap = {
          'RCT (Root Canal)': 5,
          'Dental Implant': 10,
          'Zirconia Crown': 4,
          'Fixed Braces': 8,
          'Clear Aligners': 15,
          'Cosmetic Veneers': 7,
          'Smile Makeover': 12,
          'Simple Extraction': 1,
          'Surgical Wisdom Removal': 4,
          'Professional Cleaning': 2,
          'Teeth Whitening': 3,
          'Complete Denture': 5,
          'Composite Filling': 1,
          'Gum Treatment (Laser)': 6,
          'Pediatric Dentistry': 2,
          'Full Mouth Rehab': 20,
          'Scaling & Polishing': 2,
          'Dental X-Ray (RVG)': 1,
          'Clinical Consultation': 1
        };
        return pointsMap[type];
      }

      // Read access
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.clinicianId == request.auth.uid ||
        resource.data.associateId == request.auth.uid
      );

      // Create access with strict points validation
      allow create: if isAuthenticated() && (
        // Case 1: Associate submission
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'associate' &&
         request.resource.data.associateId == request.auth.uid &&
         request.resource.data.points == getPoints(request.resource.data.treatmentType)) ||
        // Case 2: Clinician self-submission
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinician' &&
         request.resource.data.clinicianId == request.auth.uid &&
         request.resource.data.points == getPoints(request.resource.data.treatmentType))
      );
      
      // Only Admins or assigned Clinician can update (but Clinician can't change status/points)
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (resource.data.clinicianId == request.auth.uid && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'points', 'associateId']))
      );
      
      allow delete: if isAdmin();
    }

    // Payouts (General/Associates)
    match /payouts/{payoutId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.clinicianId == request.auth.uid || resource.data.associateId == request.auth.uid);
      allow create: if isAuthenticated() && (request.resource.data.clinicianId == request.auth.uid || request.resource.data.associateId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Clinician Specific Payouts
    match /clinicianPayouts/{payoutId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.clinicianId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.clinicianId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      // Users can only see their own notifications
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Admins can create notifications, users can update their own (mark as read)
      allow write: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
    }
  }
}
